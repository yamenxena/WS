# Majaz AI OS — gitignore
# Privacy-first: operational data stays local, governance is version-controlled.

# Operational data (private)
operations/
_legacy/

# Environment / secrets
.env
*.env

# Session logs
operations/logs/

# Obsidian internals
.obsidian/

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# Notion exports (large data, stays local)
Notion/

# OS files
Thumbs.db
.DS_Store

# Temp
/tmp/
*.log
